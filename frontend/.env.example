# Token PÚBLICO do Mapbox (começa com pk.). Crie em https://account.mapbox.com/
# Copie este arquivo para .env e cole seu token. NUNCA use um token secreto (sk.).
VITE_MAPBOX_TOKEN=pk.COLE_SEU_TOKEN_PUBLICO_AQUI

# Caminho base do site (precisa terminar com /). Para GitHub Pages em
# https://usuario.github.io/ofertas-voo/ mantenha o padrão abaixo.
# VITE_BASE=/ofertas-voo/
